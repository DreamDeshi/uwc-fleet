{
  "expo": {
    "name": "UWC Trucking",
    "slug": "uwc-fleet",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "uwcfleet",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#003087"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "my.uwc.fleet"
    },
    "android": {
      "package": "my.uwc.fleet",
      "adaptiveIcon": {
        "backgroundColor": "#003087"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      }
    },
    "plugins": [
      "expo-localization",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "UWC Trucking uses your location to show the live position of your truck to dispatch while you are on an active delivery."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "UWC Trucking uses your camera to capture proof-of-delivery photos at each stop.",
          "photosPermission": "UWC Trucking accesses your photos so you can attach delivery orders and invoices to a booking."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#003087"
        }
      ]
    ],
    "extra": {
      "//": "Production API on Railway. For local dev against your machine, set this to your LAN IP, e.g. http://192.168.100.154:3000 (localhost only works on the iOS simulator).",
      "apiUrl": "https://uwc-api-production.up.railway.app",
      "eas": {
        "projectId": "6cb19185-a273-4dad-9993-bc3ef859cc17"
      }
    }
  }
}
