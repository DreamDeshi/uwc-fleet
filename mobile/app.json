{
  "expo": {
    "name": "UWC Trucking",
    "slug": "uwc-fleet",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "uwcfleet",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#003087"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "my.uwc.fleet"
    },
    "android": {
      "package": "my.uwc.fleet",
      "adaptiveIcon": {
        "backgroundColor": "#003087"
      }
    },
    "plugins": ["expo-localization"],
    "extra": {
      "//": "Set apiUrl to your machine's LAN IP when running on a physical phone via Expo Go. localhost only works on the iOS simulator.",
      "apiUrl": "http://192.168.100.154:3000"
    }
  }
}
