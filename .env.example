# Database (get from Railway after creating PostgreSQL service)
DATABASE_URL="postgresql://user:password@host:port/dbname"

# JWT (generate random 64-char strings)
JWT_ACCESS_SECRET="replace-with-random-64-char-string"
JWT_REFRESH_SECRET="replace-with-different-random-64-char-string"
JWT_ACCESS_EXPIRY="30m"
JWT_REFRESH_EXPIRY="7d"

# Server
PORT=3000
NODE_ENV=development

# Cloudinary (photo/document storage — get from cloudinary.com free account)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Google Maps — NO LONGER USED by the API. Road geometry is PRE-COMPUTED
# offline (a local OpenRouteService in Docker) and shipped as RouteLeg data;
# there is no runtime routing provider and no key to obtain. See
# api/scripts/gen-route-legs.ts. The Android app still has its own separate
# googleMaps key slot in mobile/app.json (empty; the native map falls back to a
# placeholder), which is unrelated to this one.

# Expo Push Notifications (get from expo.dev)
EXPO_ACCESS_TOKEN=""

# App
APP_URL="http://localhost:3000"
# Local dev origin of the Expo web app (comma-separated allowlist in prod).
CORS_ORIGIN="http://localhost:8081"

# Stuck-trip attention report (GET /reports/attention) thresholds, in hours
ATTENTION_STALE_INPROGRESS_HOURS=8
ATTENTION_OVERDUE_ASSIGNED_HOURS=2

# Operating-window drive scaling: zone points equal to ONE flat OP_DRIVE_MIN_PER_LEG
OP_DRIVE_POINTS_BASELINE=3
