# Database (get from Railway after creating PostgreSQL service)
DATABASE_URL="postgresql://user:password@host:port/dbname"

# JWT (generate random 64-char strings)
JWT_ACCESS_SECRET="replace-with-random-64-char-string"
JWT_REFRESH_SECRET="replace-with-different-random-64-char-string"
JWT_ACCESS_EXPIRY="30m"
JWT_REFRESH_EXPIRY="7d"

# Server
PORT=3000
NODE_ENV=development

# Cloudinary (photo/document storage — get from cloudinary.com free account)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Google Maps (get from Google Cloud Console)
GOOGLE_MAPS_API_KEY=""

# Expo Push Notifications (get from expo.dev)
EXPO_ACCESS_TOKEN=""

# App
APP_URL="http://localhost:3000"
CORS_ORIGIN="http://localhost:5173"
