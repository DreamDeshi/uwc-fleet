# Database.
# LOCAL DEV: point at the Docker test DB (start it with `npm run test:db:up`
# from the repo root). The dev server and `prisma migrate dev` refuse any
# non-local host unless ALLOW_REMOTE_DB=1 (see api/src/lib/dbGuard.ts).
DATABASE_URL="postgresql://uwc:uwc@localhost:55432/uwc_test?schema=public"
# PRODUCTION: the live DB URL lives ONLY in Railway's service env vars, never
# in a committed or local file.

# JWT (generate random 64-char strings)
JWT_ACCESS_SECRET="replace-with-random-64-char-string"
JWT_REFRESH_SECRET="replace-with-different-random-64-char-string"
JWT_ACCESS_EXPIRY="30m"
JWT_REFRESH_EXPIRY="7d"

# Server
PORT=3000
NODE_ENV=development
# API rate limit — max requests per minute per IP (default 100 when unset).
# Set 0 to disable throttling, ONLY for local testing: the browser e2e suite
# drives one API instance from one IP, so a full run shares a single budget.
# Blank/invalid values fall back to the default (a typo can't weaken prod).
# RATE_LIMIT_MAX=100

# Cloudinary (photo/document storage — get from cloudinary.com free account)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Google Maps — NO LONGER USED by the API. Road geometry is PRE-COMPUTED
# offline (a local OpenRouteService in Docker) and shipped as RouteLeg data;
# there is no runtime routing provider and no key to obtain. See
# api/scripts/gen-route-legs.ts. The Android app still has its own separate
# googleMaps key slot in mobile/app.json (empty; the native map falls back to a
# placeholder), which is unrelated to this one.

# Expo Push Notifications (get from expo.dev)
EXPO_ACCESS_TOKEN=""

# App
APP_URL="http://localhost:3000"
# Local dev origin of the Expo web app (comma-separated allowlist in prod).
CORS_ORIGIN="http://localhost:8081"

# Incentive engine (hour-of-day, 0–23, server local time)
# Off-peak rates apply at/after this hour on weekdays (default 18 = 6pm)
OFFPEAK_CUTOFF_HOUR=18
# Hour the daily trip counter rolls over to a new day (default 0 = midnight)
DAILY_RESET_HOUR=0

# Operating-window cutoff estimate (Phase 3, minutes). A delivery run's estimated
# completion = pickup + OP_LOAD_MIN + stops×OP_DRIVE_MIN_PER_LEG + stops×OP_UNLOAD_MIN_PER_STOP.
# A route finishing past the truck's operating window (07:00–02:00 by default,
# per-truck via Truck.operating_hours_*) is skipped+flagged in auto mode and
# warned (overridable) in manual mode. Flat per-leg estimate; refine later.
OP_LOAD_MIN=30
OP_UNLOAD_MIN_PER_STOP=20
OP_DRIVE_MIN_PER_LEG=45

# GPS hardware vendor — static API key the in-truck GPS devices send as
# `Authorization: Bearer <key>` to POST /locations (alternative to a driver JWT).
# Generate a random 64-char hex string; leave blank to disable vendor auth.
GPS_VENDOR_API_KEY=""
