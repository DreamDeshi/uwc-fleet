# Database (get from Railway after creating PostgreSQL service)
DATABASE_URL="postgresql://user:password@host:port/dbname"

# JWT (generate random 64-char strings)
JWT_ACCESS_SECRET="replace-with-random-64-char-string"
JWT_REFRESH_SECRET="replace-with-different-random-64-char-string"
JWT_ACCESS_EXPIRY="30m"
JWT_REFRESH_EXPIRY="7d"

# Server
PORT=3000
NODE_ENV=development

# Cloudinary (photo/document storage — get from cloudinary.com free account)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Google Maps (get from Google Cloud Console)
GOOGLE_MAPS_API_KEY=""

# Expo Push Notifications (get from expo.dev)
EXPO_ACCESS_TOKEN=""

# App
APP_URL="http://localhost:3000"
CORS_ORIGIN="http://localhost:5173"

# Incentive engine (hour-of-day, 0–23, server local time)
# Off-peak rates apply at/after this hour on weekdays (default 18 = 6pm)
OFFPEAK_CUTOFF_HOUR=18
# Hour the daily trip counter rolls over to a new day (default 0 = midnight)
DAILY_RESET_HOUR=0

# Operating-window cutoff estimate (Phase 3, minutes). A delivery run's estimated
# completion = pickup + OP_LOAD_MIN + stops×OP_DRIVE_MIN_PER_LEG + stops×OP_UNLOAD_MIN_PER_STOP.
# A route finishing past the truck's operating window (07:00–18:00 by default,
# per-truck via Truck.operating_hours_*) is skipped+flagged in auto mode and
# warned (overridable) in manual mode. Flat per-leg estimate; refine later.
OP_LOAD_MIN=30
OP_UNLOAD_MIN_PER_STOP=20
OP_DRIVE_MIN_PER_LEG=45

# GPS hardware vendor — static API key the in-truck GPS devices send as
# `Authorization: Bearer <key>` to POST /locations (alternative to a driver JWT).
# Generate a random 64-char hex string; leave blank to disable vendor auth.
GPS_VENDOR_API_KEY=""
