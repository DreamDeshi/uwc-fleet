{
  "name": "uwc-fleet-api",
  "version": "1.0.0",
  "private": true,
  "description": "UWC Trucking — Node.js + Express + Prisma backend",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "gen:spec": "node scripts/gen-spec.mjs",
    "start": "node dist/index.js",
    "migrate:deploy": "prisma migrate deploy",
    "seed": "tsx prisma/seed.ts",
    "seed:test": "tsx prisma/seed-test.ts",
    "test": "vitest run",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "prisma:migrate": "tsx prisma/dev-guard.ts prisma:migrate && prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:studio": "tsx prisma/dev-guard.ts prisma:studio && prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "prisma": "^5.20.0",
    "bcrypt": "^5.1.1",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "swagger-ui-express": "^5.0.1",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.16.0",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
